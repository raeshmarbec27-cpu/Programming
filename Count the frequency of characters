//Write a C program to count the frequency of each character in a given string.

#include <stdio.h>
void count(char a[]) {
    int c = 0;
    for (int i = 0; a[i] != '\0'; i++) {
        int counted = 0;
        for (int k = 0; k < i; k++) {
            if (a[i] == a[k]) {
                counted = 1;
                break;
            }
        }
        if (counted) {
            continue;
        }
        for (int j = 0; a[j] != '\0'; j++) {
            if (a[i] == a[j]) {
                c++;
            }
        }
        printf("The letter %c occurs %d times\n", a[i], c);    
        c = 0; 
    }
}

int main() {
    char str[50];
    printf("Enter a string: ");
    scanf("%s", str);
    count(str);
    return 0;
}
