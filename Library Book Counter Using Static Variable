//Develop a C program to track the total number of books added to a library. Use a static variable to maintain the count and display the count whenever a new book is added.
Sample Input
Books Added: 3
Sample Output
Book Added
Total Books: 1

Book Added
Total Books: 2

Book Added
Total Books: 3


#include <stdio.h>
void addBook() {
    static int total = 0; 
    total++;
    printf("\nBook Added\nTotal Books: %d\n", total);
}

int main() {
    int n;
    printf("Books Added: ");
    scanf("%d", &n);
    for (int i = 0; i < n; i++) {
        addBook();
    }
    
    return 0;
}
